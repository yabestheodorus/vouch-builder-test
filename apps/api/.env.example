# Copy to .env and fill in. .env is gitignored.

# API server
PORT="3001"
WEB_ORIGIN="http://localhost:3000"

# SQLite database file (relative to apps/api)
DATABASE_URL="file:./dev.db"

# Groq LLM
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# Prompt version recorded in every GenerationLog (bump on prompt changes)
PROMPT_VERSION="v1"
